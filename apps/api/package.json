{
  "name": "@llm-local/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "start": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "job:refresh": "tsx src/jobs/refresh-data.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@llm-local/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
